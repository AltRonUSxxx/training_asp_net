@page
@model IndexModel
@{
    ViewData["Title"] = "Форма регистрации";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card-body">
           <h2 class="text-center mb-4">Регистрация на мероприятие!</h2>
           <form method="post" asp-page-handler="Add">
               <div class="mb-3">
                   <label class="form-label">Имя</label>
                    <input asp-for="_name" class="form-control" />
               </div>
                <div class="mb-3">
                    <label class="form-label">Возраст</label>
                    <input asp-for="_age" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Дополнительная информация</label>
                    <input asp-for="_AdditionalInfo" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input asp-for="_email" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Пароль</label>
                    <input type="password" asp-for="_password" class="form-control" />
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-primary">
                           Регистрация
                    </button>
                </div>
            
            </form>
            @if(Model._error != null)
            {   
                <div class="alert alert-danger mt-4">
                    @Model._error;
                </div>
            }
            @if (Model._name != null && Model._error == null)
            {
                <div class="alert alert-success mt-4">
                    <h5>Вы успешно зарегистрировались</h5>
                    <p><b>Имя:</b> @Model._name</p>
                    <p><b>Возраст:</b> @Model._age</p>
                    <p><b>Дополнительная информация:</b> @Model._AdditionalInfo</p>
                    <p><b>Почта:</b> @Model._email</p>
                    <p><b>Пароль:</b> @Model._password</p>
                    <p> Регистрация прошла успешно!</p>
                    <p> Добро пожаловать, !</p>

                    Регистрация прошла успешно!
                    Добро пожаловать, @Model._name!
                </div>
            }

        </div>
        @if (IndexModel.Humans.Count > 0)
        {
            <div class="mt-5">
                <h3 class="text-center">Список участников</h3>
                <div class="mb-3">
                    <input asp-for="whatFind" class="form-control" />
                </div>
                <div class="d-grid">
                    <button id="what_find" class="btn btn-primary" onclick="@Model.what_find_click()">
                        Поиск
                    </button>
                </div>
                <table class="table table-striped mt-3">
                    <thead>
                        <tr>
                            <th>Номер</th>
                            <th>Имя</th>
                            <th>Возраст</th>
                            <th>Дополнительная информация</th>
                            <th>Email</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < IndexModel.HumansFiltred.Count; i++)
                        {
                            <tr>
                                <td>@(i + 1)</td>
                                <td>@IndexModel.HumansFiltred[i].Name</td>
                                <td>@IndexModel.HumansFiltred[i].Age</td>
                                <td>@IndexModel.HumansFiltred[i].AdditionalInfo</td>
                                <td>@IndexModel.HumansFiltred[i].Email</td>
                                <td>
                                    <form method="post" asp-page-handler="Delete">
                                        <input type="hidden" name="index" value="@i"/>
                                        <button class="btn btn-danger btn-sm">Удалить</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
